{
  "name": "v1",
  "version": "1.0.0",
  "description": "TMDB 영화 커뮤니티 플랫폼 — Express 백엔드",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "client": "npm start --prefix client",
